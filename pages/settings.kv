#:kivy 2.1.0
#:import dp kivy.metrics.dp
#:import ThemeSelectButton widgets.select_button.ThemeSelectButton
#:import LanguageSelectButton widgets.select_button.LanguageSelectButton
#:import VariantSelectButton widgets.select_button.VariantSelectButton


<SettingsScreen>:
    name: "settings"
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(16)

        # Верхний блок: Тема и Язык
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(16)
            size_hint_y: None
            height: dp(240)
            
            # Настройки темы
            OverlayCard:
                size_hint_x: 0.6
                padding: dp(16)
                
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(16)
                    
                    # Заголовок темы
                    Label:
                        id: theme_section_label
                        text: "Theme Settings"
                        font_size: '20sp'
                        font_name: app.theme_manager.get_font("title") if app.theme_manager else ""
                        color: app.theme_manager.get_rgba("primary") if app.theme_manager else [1,1,1,1]
                        size_hint_y: None
                        height: dp(32)
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    
                    # Выбор темы
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(16)
                        size_hint_y: None
                        height: dp(56)
                        
                        Label:
                            id: theme_label
                            text: "Theme:"
                            font_size: '16sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.35
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        ThemeSelectButton:
                            id: theme_select_button
                            text: root.current_theme
                            values: root.theme_list
                            font_size: '16sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            background_normal: app.theme_manager.get_image("button_bg") if app.theme_manager else ""
                            background_down: app.theme_manager.get_image("button_bg_active") if app.theme_manager else ""
                            size_hint_x: 0.65
                            disabled: not root.theme_selector_enabled
                            opacity: 1.0 if root.theme_selector_enabled else 0.5
                    
                    # Выбор режима (light/dark)
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(16)
                        size_hint_y: None
                        height: dp(56)
                        
                        Label:
                            id: variant_label
                            text: "Mode:"
                            font_size: '16sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.35
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        VariantSelectButton:
                            id: variant_select_button
                            text: root.current_variant
                            values: root.variant_list
                            popup_title: "Select Mode"
                            font_size: '16sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            background_normal: app.theme_manager.get_image("button_bg") if app.theme_manager else ""
                            background_down: app.theme_manager.get_image("button_bg_active") if app.theme_manager else ""
                            # 🔥 КРИТИЧЕСКОЕ ИСПРАВЛЕНИЕ: Фиксированный размер для предотвращения WeakProxy
                            size_hint: None, None
                            size: dp(200), dp(48)
                            pos_hint: {'x': 0}
                    
                    # Заполнитель для выравнивания
                    Widget:
            
            # Настройки языка
            OverlayCard:
                size_hint_x: 0.4
                padding: dp(16)
                
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(16)
                    
                    # Заголовок языка
                    Label:
                        id: language_section_label
                        text: "Language Settings"
                        font_size: '20sp'
                        font_name: app.theme_manager.get_font("title") if app.theme_manager else ""
                        color: app.theme_manager.get_rgba("primary") if app.theme_manager else [1,1,1,1]
                        size_hint_y: None
                        height: dp(32)
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    
                    # Выбор языка
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(16)
                        size_hint_y: None
                        height: dp(56)
                        
                        Label:
                            id: language_label
                            text: "Language:"
                            font_size: '16sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.35
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        LanguageSelectButton:
                            id: language_select_button
                            text: root.current_language
                            values: root.language_list
                            popup_title: "Select Language"
                            font_size: '16sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            background_normal: app.theme_manager.get_image("button_bg") if app.theme_manager else ""
                            background_down: app.theme_manager.get_image("button_bg_active") if app.theme_manager else ""
                            # 🔥 НОВОЕ: Фиксированный размер для стабильности
                            size_hint: None, None
                            size: dp(200), dp(48)
                            pos_hint: {'x': 0}
                    
                    # Заполнитель
                    Widget:

        # Средний блок: Персональные настройки
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(16)
            size_hint_y: None
            height: dp(200)
            
            # Персональная информация
            OverlayCard:
                size_hint_x: 0.5
                padding: dp(16)
                
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(12)
                    
                    # Заголовок
                    Label:
                        id: personal_section_label
                        text: "Personal Settings"
                        font_size: '18sp'
                        font_name: app.theme_manager.get_font("title") if app.theme_manager else ""
                        color: app.theme_manager.get_rgba("primary") if app.theme_manager else [1,1,1,1]
                        size_hint_y: None
                        height: dp(28)
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    
                    # Имя пользователя
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(40)
                        
                        Label:
                            id: username_label
                            text: "Name:"
                            font_size: '14sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.3
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        TextInput:
                            id: username_input
                            text: root.username
                            font_size: '14sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            foreground_color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            background_color: app.theme_manager.get_rgba("background_highlighted") if app.theme_manager else [0.2,0.2,0.2,1]
                            multiline: False
                            size_hint_x: 0.7
                            on_text: root.on_username_change(self, self.text)
                    
                    # День рождения
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(40)
                        
                        Label:
                            id: birthday_label
                            text: "Birthday:"
                            font_size: '14sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.3
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        # День
                        TextInput:
                            id: birth_day_input
                            text: root.birth_day
                            font_size: '14sp'
                            input_filter: 'int'
                            multiline: False
                            size_hint_x: 0.2
                            hint_text: "DD"
                            on_text: root.on_birth_day_change(self, self.text)
                        
                        # Месяц
                        TextInput:
                            id: birth_month_input
                            text: root.birth_month
                            font_size: '14sp'
                            input_filter: 'int'
                            multiline: False
                            size_hint_x: 0.25
                            hint_text: "MM"
                            on_text: root.on_birth_month_change(self, self.text)
                        
                        # Год
                        TextInput:
                            id: birth_year_input
                            text: root.birth_year
                            font_size: '14sp'
                            input_filter: 'int'
                            multiline: False
                            size_hint_x: 0.25
                            hint_text: "YYYY"
                            on_text: root.on_birth_year_change(self, self.text)
                    
                    # Заполнитель
                    Widget:
            
            # Автоматическая тема
            OverlayCard:
                size_hint_x: 0.5
                padding: dp(16)
                
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(12)
                    
                    # Заголовок
                    Label:
                        id: auto_theme_section_label
                        text: "Auto Theme"
                        font_size: '18sp'
                        font_name: app.theme_manager.get_font("title") if app.theme_manager else ""
                        color: app.theme_manager.get_rgba("primary") if app.theme_manager else [1,1,1,1]
                        size_hint_y: None
                        height: dp(28)
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    
                    # Переключатель автотемы
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(40)
                        
                        Label:
                            id: auto_theme_label
                            text: "Auto Theme:"
                            font_size: '14sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.6
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        CheckBox:
                            id: auto_theme_checkbox
                            active: root.auto_theme_enabled
                            size_hint_x: 0.4
                            on_active: root.on_auto_theme_toggle(self, self.active)
                    
                    # Порог чувствительности
                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(40)
                        
                        Label:
                            id: threshold_label
                            text: "Threshold:"
                            font_size: '14sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                            size_hint_x: 0.4
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                        
                        Slider:
                            id: threshold_slider
                            min: 1
                            max: 10
                            value: root.light_sensor_threshold
                            step: 1
                            size_hint_x: 0.5
                            disabled: not root.auto_theme_enabled
                            on_value: root.on_threshold_change(self, self.value)
                        
                        Label:
                            id: threshold_value_label
                            text: f"{int(root.light_sensor_threshold)}s"
                            font_size: '12sp'
                            font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                            color: app.theme_manager.get_rgba("text_secondary") if app.theme_manager else [0.7,0.7,0.7,1]
                            size_hint_x: 0.1
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                    
                    # Заполнитель
                    Widget:

        # Нижний блок: Управление громкостью
        OverlayCard:
            size_hint_y: None
            height: dp(120)
            padding: dp(16)
            
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(12)
                
                # Заголовок
                Label:
                    id: volume_section_label
                    text: "Volume Control"
                    font_size: '18sp'
                    font_name: app.theme_manager.get_font("title") if app.theme_manager else ""
                    color: app.theme_manager.get_rgba("primary") if app.theme_manager else [1,1,1,1]
                    size_hint_y: None
                    height: dp(28)
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                
                # Слайдер громкости
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(16)
                    size_hint_y: None
                    height: dp(40)
                    
                    Label:
                        id: volume_label
                        text: "Volume:"
                        font_size: '14sp'
                        font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                        color: app.theme_manager.get_rgba("text") if app.theme_manager else [1,1,1,1]
                        size_hint_x: 0.15
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                    
                    Slider:
                        id: volume_slider
                        min: 0
                        max: 100
                        value: root.current_volume
                        step: 5
                        size_hint_x: 0.7
                        disabled: not root.volume_service_available
                        on_value: root.on_volume_change(self, self.value)
                    
                    Label:
                        id: volume_value_label
                        text: f"{int(root.current_volume)}%"
                        font_size: '14sp'
                        font_name: app.theme_manager.get_font("main") if app.theme_manager else ""
                        color: app.theme_manager.get_rgba("text_secondary") if app.theme_manager else [0.7,0.7,0.7,1]
                        size_hint_x: 0.15
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                
                # Заполнитель
                Widget: